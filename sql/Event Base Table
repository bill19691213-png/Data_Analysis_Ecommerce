CREATE OR REPLACE TABLE `project-cf626adc-1290-4ce9-aae.Ecommerce.ecommerce_event_base` AS
WITH base AS (
  SELECT
    PARSE_DATE('%Y%m%d', event_date) AS event_date,
    TIMESTAMP_MICROS(event_timestamp) AS event_ts,
    event_name,

    user_pseudo_id,
    user_id,

    -- session fields
    (SELECT value.int_value
     FROM UNNEST(event_params)
     WHERE key = 'ga_session_id'
     LIMIT 1) AS ga_session_id,

    CONCAT(
      user_pseudo_id,
      '-',
      CAST((
        SELECT value.int_value
        FROM UNNEST(event_params)
        WHERE key = 'ga_session_id'
        LIMIT 1
      ) AS STRING)
    ) AS session_id,

    (SELECT value.int_value
     FROM UNNEST(event_params)
     WHERE key = 'ga_session_number'
     LIMIT 1) AS ga_session_number,

    -- page / event context
    (SELECT value.string_value
     FROM UNNEST(event_params)
     WHERE key = 'page_location'
     LIMIT 1) AS page_location,

    (SELECT value.string_value
     FROM UNNEST(event_params)
     WHERE key = 'page_title'
     LIMIT 1) AS page_title,

    (SELECT value.string_value
     FROM UNNEST(event_params)
     WHERE key = 'page_referrer'
     LIMIT 1) AS page_referrer,

    (SELECT value.string_value
     FROM UNNEST(event_params)
     WHERE key = 'currency'
     LIMIT 1) AS currency,

    (SELECT value.double_value
     FROM UNNEST(event_params)
     WHERE key = 'value'
     LIMIT 1) AS event_value,

    (SELECT value.int_value
     FROM UNNEST(event_params)
     WHERE key = 'engagement_time_msec'
     LIMIT 1) AS engagement_time_msec,

    -- device
    device.category AS device_category,
    device.operating_system AS device_os,
    device.web_info.browser AS browser,
    device.web_info.hostname AS hostname,

    -- geography
    geo.country AS country,
    geo.region AS region,
    geo.city AS city,

    -- acquisition: this is FIRST-USER source, not session source
    traffic_source.source AS first_user_source,
    traffic_source.medium AS first_user_medium,
    traffic_source.name AS first_user_campaign,

    -- ecommerce
    ecommerce.transaction_id AS transaction_id,
    ecommerce.purchase_revenue AS purchase_revenue,
    ecommerce.shipping_value AS shipping_value,
    ecommerce.tax_value AS tax_value,
    ecommerce.total_item_quantity AS total_item_quantity,
    ecommerce.unique_items AS unique_items,

    -- helper flags for easier analysis later
    CASE WHEN event_name = 'view_item' THEN 1 ELSE 0 END AS is_view_item,
    CASE WHEN event_name = 'add_to_cart' THEN 1 ELSE 0 END AS is_add_to_cart,
    CASE WHEN event_name = 'begin_checkout' THEN 1 ELSE 0 END AS is_begin_checkout,
    CASE WHEN event_name = 'purchase' THEN 1 ELSE 0 END AS is_purchase

  FROM `bigquery-public-data.ga4_obfuscated_sample_ecommerce.events_*`
  WHERE _TABLE_SUFFIX BETWEEN '20201101' AND '20210131'
)

SELECT *
FROM base;
